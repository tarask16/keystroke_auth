{
    "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestArgs": [
        "tests"
    ],
    "editor.formatOnSave": true,
    "ruff.enable": true,
    "taskButtons.showCounter": true,
    "taskButtons.buttons": [
        {
            "label": "$(database) data_loader",
            "task": "Run data_loader"
        },
        {
            "label": "$(beaker) tests",
            "task": "Run tests"
        },
        {
            "label": "$(check) ruff",
            "task": "Ruff check"
        },
        {
            "label": "$(tools) ruff fix",
            "task": "Ruff fix"
        }
    ]
}