{
    "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestArgs": [
        "tests"
    ],
    "editor.formatOnSave": true,
    "ruff.enable": true,
    "actionButtons": {
        "defaultColor": "white",
        "loadNpmCommands": false,
        "reloadButton": "↻",
        "commands": [
            {
                "name": "$(database) data_loader",
                "color": "lightgreen",
                "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe -m src.data_loader",
                "cwd": "${workspaceFolder}",
                "singleInstance": true,
                "focus": true,
                "tooltip": "Run CMU data_loader"
            },
            {
                "name": "$(beaker) tests",
                "color": "lightskyblue",
                "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe -m pytest",
                "cwd": "${workspaceFolder}",
                "singleInstance": true,
                "focus": true,
                "tooltip": "Run pytest"
            },
            {
                "name": "$(check) ruff",
                "color": "khaki",
                "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe -m ruff check .",
                "cwd": "${workspaceFolder}",
                "singleInstance": true,
                "focus": true,
                "tooltip": "Run Ruff check"
            },
            {
                "name": "$(tools) ruff fix",
                "color": "orange",
                "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe -m ruff check . --fix",
                "cwd": "${workspaceFolder}",
                "singleInstance": true,
                "focus": true,
                "tooltip": "Run Ruff auto-fix"
            }
        ]
    }
}